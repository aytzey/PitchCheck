# OpenRouter (for LLM persuasion interpretation)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-sonnet-4.6
OPENROUTER_TIMEOUT_SECONDS=20

# TRIBE model
TRIBE_MODEL_ID=facebook/tribev2
TRIBE_DEVICE=cuda
TRIBE_CACHE_DIR=/models
TRIBE_ALLOW_MOCK=0
TRIBE_SERVICE_URL=http://tribe-service:8090

# Desktop runtime defaults
PITCHCHECK_TRIBE_IMAGE=ghcr.io/aytzey/pitchcheck-tribe:latest
