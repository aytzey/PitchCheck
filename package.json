{
  "name": "pitchcheck",
  "version": "0.1.2",
  "private": true,
  "description": "Score your sales pitch against a neuroscience model before you send it. Desktop app with local GPU and Vast.ai cloud fallback.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aytzey/PitchCheck.git"
  },
  "bugs": {
    "url": "https://github.com/aytzey/PitchCheck/issues"
  },
  "homepage": "https://github.com/aytzey/PitchCheck#readme",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:desktop-web": "node scripts/build-desktop-web.mjs",
    "tauri": "tauri",
    "desktop:dev": "tauri dev",
    "desktop:build": "node scripts/build-desktop-installer.mjs",
    "desktop:check": "cargo check --manifest-path src-tauri/Cargo.toml",
